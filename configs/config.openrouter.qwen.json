{
  "llm": {
    "provider": "openrouter",
    "apiKey": "${OPENROUTER_API_KEY}",
    "model": "qwen/qwen3.5-397b-a17b",
    "contextWindow": 262144,
    "baseUrl": "https://openrouter.ai/api/v1",
    "temperature": 0.7,
    "top-p": 1.0,
    "maxTokens": 16384,
    "thinking": {
      "enabled": true,
      "budgetLevel": "high",
      "fallbackToPrompt": false
    },
    "providerRouting": {
      "order": [
        "alibaba"
      ],
      "allowFallbacks": false
    }
  },
  "executor": {
    "enabled": true,
    "model": "qwen/qwen3.5-397b-a17b",
    "timeoutMs": 180000,
    "maxIterations": 20,
    "providerRouting": {
      "order": [
        "alibaba"
      ],
      "allowFallbacks": false
    }
  },
  "tools": {
    "whitelist": [
      "run_subtask"
    ]
  },
  "agent": {
    "systemPrompt": "You are a web assistant with browser use tools.\n\n"
  },
  "storage": {
    "maxSessionStorageMb": 1000,
    "autoCleanupDays": 90
  },
  "skills": {
    "preload": [
    ],
    "comment": "Preload skills make their tools available immediately without LLM calling read_skill"
  },
  "gateways": {
    "default": {
      "authMethod": "none",
      "url": "ws://localhost:8080"
    }
  },
  "defaultGateway": "default"
}
